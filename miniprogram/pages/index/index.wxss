.page {
  min-height: 100vh;
  background: linear-gradient(170deg, #f9f6f0 0%, #f0ece4 40%, #e8e4db 100%);
  padding: 40rpx;
}

.card {
  background: rgba(255,255,255,0.8);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1c1c1e;
  display: block;
}

.sub {
  font-size: 28rpx;
  color: rgba(0,0,0,0.4);
  display: block;
  margin-top: 8rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
}

.input-wrap input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fff;
  margin-right: 16rpx;
}

.input-wrap button {
  width: 160rpx;
  height: 80rpx;
  background: #1c1c1e;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}
